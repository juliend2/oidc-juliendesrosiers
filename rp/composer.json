{
    "name": "app/oidc-rp",
    "description": "OIDC Relying Party",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^7.0",
        "jumbojett/openid-connect-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
